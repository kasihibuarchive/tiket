# ═══════════════════════════════════════
# TEATERAN — Environment Variables
# Copy this to .env.local and fill in
# Set all these in Vercel → Settings → Environment Variables
# ═══════════════════════════════════════

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres.[DB_ID]:[DB_PASS]@aws-0-[region].pooler.supabase.com:6543/postgres

# App Secret (for NextAuth session tokens & password hashing)
APP_SECRET=your-app-secret-here

# MidTrans Payment Gateway
MIDTRANS_SERVER_KEY=Mid-server-xxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-xxxx

# App URL (set to your Vercel domain, e.g. https://teateran.vercel.app)
NEXT_PUBLIC_APP_URL=https://teateran.vercel.app

# Email (Nodemailer)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Vercel deployment flag (set automatically by Vercel, no need to set manually)
# DEPLOY_TARGET=vercel
