# Tripay API Credentials (dari dashboard Tripay kamu)
TRIPAY_API_KEY=your_api_key_here
TRIPAY_PRIVATE_KEY=your_private_key_here
TRIPAY_MERCHANT_CODE=your_merchant_code_here
TRIPAY_IS_PRODUCTION=false

# Proxy auth key — copy ini ke Vercel env var TRIPAY_PROXY_AUTH_KEY
PROXY_AUTH_KEY=bikin_random_string_disini

# Opsional: batasi hanya dari domain Teateran
ALLOWED_ORIGIN=https://www.teateran.site
